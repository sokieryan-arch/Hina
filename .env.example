# AI_PROVIDER: Optional. Use "openai" or "gemini".
# If omitted, the server uses OPENAI_API_KEY first and falls back to GEMINI_API_KEY.
AI_PROVIDER="openai"

# OPENAI_API_KEY: Required when using OpenAI for chat and TTS.
OPENAI_API_KEY="MY_OPENAI_API_KEY"
OPENAI_CHAT_MODEL="gpt-4o-mini"
OPENAI_TTS_MODEL="tts-1"
OPENAI_TTS_VOICE="nova"
OPENAI_REQUEST_TIMEOUT_MS="20000"

# GEMINI_API_KEY: Optional fallback for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_CHAT_MODEL="gemini-3.5-flash"
GEMINI_TTS_MODEL="gemini-3.1-flash-tts-preview"
GEMINI_TTS_VOICE="Aoede"
GEMINI_REQUEST_TIMEOUT_MS="30000"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

FIREBASE_PROJECT_ID="gen-lang-client-0446612903"
FIREBASE_WEB_API_KEY="your_firebase_web_api_key"
FIREBASE_FIRESTORE_DATABASE_ID="ai-studio-f545bc87-5883-43c8-b172-c964c6c056a8"
FIREBASE_STORAGE_BUCKET="gen-lang-client-0446612903.firebasestorage.app"

# Production quota persistence and Firebase ID-token verification use Firebase Admin when configured.
# Use one of:
# FIREBASE_ADMIN_SERVICE_ACCOUNT_JSON='{"project_id":"...","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"}'
# or FIREBASE_ADMIN_CLIENT_EMAIL="" and FIREBASE_ADMIN_PRIVATE_KEY=""

FREE_DAILY_CHAT_LIMIT="30"
PRO_DAILY_CHAT_LIMIT="0"

# Paddle checkout for Hina Pro. The price ID is public; client token is public but should
# still be scoped in Paddle. Webhook secret is server-only and must not be exposed with VITE_.
VITE_PADDLE_CLIENT_TOKEN="test_or_live_client_side_token"
VITE_PADDLE_ENVIRONMENT="production"
VITE_PADDLE_PRICE_ID="pri_01kwxsfc7hyn0b94ptrtf7y2ek"
PADDLE_PRICE_ID="pri_01kwxsfc7hyn0b94ptrtf7y2ek"
PADDLE_WEBHOOK_SECRET="pdl_ntfset_..."
