GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_CHAT_MODEL="gemini-3.5-flash"
GEMINI_TTS_MODEL="gemini-3.1-flash-tts-preview"
GEMINI_TTS_VOICE="Aoede"

APP_URL="MY_APP_URL"

# required in production by default, optional in development.
# Use disabled only for throwaway local demos.
AI_AUTH_MODE="optional"
FIREBASE_PROJECT_ID="gen-lang-client-0446612903"

CHAT_RATE_LIMIT_PER_MINUTE="30"
TTS_RATE_LIMIT_PER_MINUTE="10"
PROACTIVE_RATE_LIMIT_PER_HOUR="12"

# Future adapter hook for mainland China deployments.
LLM_PROVIDER="gemini"
